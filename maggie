        senha = self.ent_senha.get().strip()
        
        if not self.pasta_destino:
            # Trava de Segurança: Apenas o ADM pode provisionar o banco de dados inicial
            if usuario == "ADM" and senha == "147":
                self.configurar_primeiro_acesso()
            else:
                messagebox.showerror("Acesso Negado", "O primeiro acesso para criação do banco de dados\ndeve ser feito pelo usuário ADM.")
        else:
            if usuario == "ADM" and senha == "147":
                self.usuario_logado = "ADM"
                self.iniciar_sistema()
            elif usuario == "OPER" and senha == "123":
                self.usuario_logado = "OPER"
                self.iniciar_sistema()
            else:
                messagebox.showerror("Acesso Negado", "Usuário ou senha inválidos.")

    def configurar_primeiro_acesso(self):
        """Provisiona a pasta local e cria o arquivo de configuração de memória (maggie_config.txt)."""
        pasta_base = filedialog.askdirectory(title="Selecione a pasta principal para salvar os dados")
        if not pasta_base:
            messagebox.showwarning("Aviso", "Configuração cancelada.")
            return
            
        self.pasta_destino = os.path.join(pasta_base, 'maggie_dados')
        os.makedirs(self.pasta_destino, exist_ok=True)
        
        with open(self.arquivo_config, "w") as f:
            f.write(self.pasta_destino)
            
        self.usuario_logado = "ADM"
        self.iniciar_sistema()

    def iniciar_sistema(self):
        """Constrói a interface principal do CRM de acordo com o nível de permissão (RBAC)."""
        self.root.unbind('<Return>') # Previne interferência do Enter nas caixas de texto
        
        # Estabelece conexão ou cria o banco no local provisionado
        caminho_db = os.path.join(self.pasta_destino, 'pet_clinic.db')
        self.db = BancoDados(caminho_db)
        
        # Transição de telas
        self.frame_login.pack_forget()
        self.frame_sistema.pack(expand=True, fill="both")
        
        # Limpeza forçada de instâncias para garantir integridade após logout
        for widget in self.frame_sistema.winfo_children():
            widget.destroy()
            
        # Barra superior com status da sessão
        frame_topo = ttk.Frame(self.frame_sistema)
        frame_topo.pack(fill="x", padx=10, pady=5)
        ttk.Label(frame_topo, text=f"Logado como: {self.usuario_logado}", font=("Arial", 9, "bold")).pack(side="left")
        self.btn_logout = ttk.Button(frame_topo, text=self.textos[self.idioma]["logout"], command=self.fazer_logout)
        self.btn_logout.pack(side="right")

