class BancoDados:
    """
    Gerencia a conexão e as operações transacionais com o banco de dados SQLite.
    Garante a criação das tabelas fundamentais caso não existam.
    """
    
    def __init__(self, caminho_db):
        """Inicializa a conexão com o banco de dados e aciona a criação das tabelas."""
        self.conn = sqlite3.connect(caminho_db)
        self.cursor = self.conn.cursor()
        self.criar_tabelas()

    def criar_tabelas(self):
        """
        Estrutura o esquema relacional do banco de dados (DDL).
        Implementa chaves primárias (PRIMARY KEY) e estrangeiras (FOREIGN KEY) 
        para garantir a integridade referencial dos dados.
        """
        self.cursor.executescript('''
            CREATE TABLE IF NOT EXISTS tutor (
                cpf TEXT PRIMARY KEY, nome TEXT, celular TEXT, email TEXT,
                cep TEXT, endereco TEXT, bairro TEXT, cidade TEXT, uf TEXT,
                usuario_registro TEXT
            );
            CREATE TABLE IF NOT EXISTS pet (
                codigo TEXT PRIMARY KEY, cpf_tutor TEXT, nome TEXT,
                tipo TEXT, raca TEXT, porte TEXT, dt_nasc TEXT, sexo TEXT, cor TEXT,
                usuario_registro TEXT,
                FOREIGN KEY(cpf_tutor) REFERENCES tutor(cpf)
            );
            CREATE TABLE IF NOT EXISTS cuidados (
                codigo_pet TEXT PRIMARY KEY, alimentacao TEXT, horarios TEXT, alergias TEXT,
                usuario_registro TEXT,
                FOREIGN KEY(codigo_pet) REFERENCES pet(codigo)
            );
            CREATE TABLE IF NOT EXISTS vacinas (
                id INTEGER PRIMARY KEY AUTOINCREMENT, codigo_pet TEXT, vacina TEXT,
                protege TEXT, duracao TEXT, proxima_dose TEXT, usuario_registro TEXT,
                FOREIGN KEY(codigo_pet) REFERENCES pet(codigo)
            );
        ''')
        self.conn.commit()

    def executar(self, query, params=()):
        """
        Executa instruções SQL (DML) de forma parametrizada, prevenindo injeção de SQL.
        Retorna o cursor para iteração (fetchall, fetchone).
        """
        self.cursor.execute(query, params)
        self.conn.commit()
        return self.cursor

