        self.tema_escuro = (self.var_tema.get() == "Escuro")
        self.aplicar_tema()

    def aplicar_tema(self):
        """Sobrescreve a estilização (Stylesheet) da GUI do Tkinter dinamicamente."""
        bg_color = "#2e2e2e" if self.tema_escuro else "#f0f0f0"
        fg_color = "#ffffff" if self.tema_escuro else "#000000"

        # Cores constantes de Tab/Notebook para garantir acessibilidade visual
        if self.tema_escuro:
            tab_fundo_barra = "#1e1e1e"; tab_fundo_desativada = "#454545"; tab_fundo_ativa = "#2e2e2e"; tab_texto = "#ffffff"; tab_hover = "#555555"
        else:
            tab_fundo_barra = "#e0e0e0"; tab_fundo_desativada = "#d9d9d9"; tab_fundo_ativa = "#f0f0f0"; tab_texto = "#000000"; tab_hover = "#e8e8e8"
        
        style = ttk.Style(); style.theme_use('clam')
        
        # Mapeamento e Estilização
        style.configure("TNotebook", background=tab_fundo_barra, borderwidth=0)
        style.configure("TNotebook.Tab", background=tab_fundo_desativada, foreground=tab_texto, padding=[10, 5])
        style.map("TNotebook.Tab", background=[("selected", tab_fundo_ativa), ("active", tab_hover)], foreground=[("selected", tab_texto)])
        style.configure("TFrame", background=bg_color)
        style.configure("TLabel", background=bg_color, foreground=fg_color)
        style.configure("TButton", background="#4a4a4a" if self.tema_escuro else "#e0e0e0", foreground=fg_color)
        style.configure("TRadiobutton", background=bg_color, foreground=fg_color)
        
        self.root.configure(bg=bg_color)
        self.header_autoria.configure(background=bg_color, foreground=fg_color)

# Execução do script com base na hierarquia orientada a objetos (OOP)
if __name__ == "__main__":
    root = tk.Tk()
    app = AppPet(root)
    root.mainloop()
