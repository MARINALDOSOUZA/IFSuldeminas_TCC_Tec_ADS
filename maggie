    def excluir(self):
        """Eliminação em Cascata: Respeita as dependências apagando as foreign keys primeiro."""
        selecionado = self.tree_mod.selection()
        if not selecionado: return messagebox.showwarning("Aviso", "Selecione um registro na lista.")
        
        codigo_pet = self.tree_mod.item(selecionado[0], "values")[0]
        confirmar = messagebox.askyesno("Confirmação", f"Deseja realmente excluir todos os dados do pet {codigo_pet}?")
        if confirmar:
            # Exclui das dependentes para não violar chaves estrangeiras
            self.db.executar("DELETE FROM vacinas WHERE codigo_pet=?", (codigo_pet,))
            self.db.executar("DELETE FROM cuidados WHERE codigo_pet=?", (codigo_pet,))
            self.db.executar("DELETE FROM pet WHERE codigo=?", (codigo_pet,))
            messagebox.showinfo("Sucesso", "Registros removidos com sucesso.")
            self.tree_mod.delete(selecionado[0])

    def carregar_modificacao(self):
