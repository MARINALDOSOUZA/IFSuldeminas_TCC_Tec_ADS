    def formatar_data(self, event):
        """Aplica a máscara DD/MM/AAAA para datas."""
        if event.keysym in ['BackSpace', 'Delete', 'Left', 'Right', 'Up', 'Down']: return
        entry = event.widget
        texto = entry.get()
        digitos = ''.join(filter(str.isdigit, texto))[:8]
        formatado = ""
        for i, d in enumerate(digitos):
            if i in [2, 4]: formatado += "/"
            formatado += d
        if texto != formatado:
            entry.delete(0, tk.END); entry.insert(0, formatado)

    def formatar_cpf_cadastro(self, event):
        """Aplica a máscara 000.000.000-00 para o CPF."""
        if event.keysym in ['BackSpace', 'Delete', 'Left', 'Right', 'Up', 'Down']: return
        entry = self.entries_tutor["cpf"]
        texto = entry.get()
        digitos = ''.join(filter(str.isdigit, texto))[:11]
        formatado = ""
        for i, d in enumerate(digitos):
            if i in [3, 6]: formatado += "."
            if i == 9: formatado += "-"
            formatado += d
        if texto != formatado:
            entry.delete(0, tk.END); entry.insert(0, formatado)

    def formatar_celular(self, event):
        """Aplica a máscara (00) 0 0000-0000 para telefones brasileiros."""
        if event.keysym in ['BackSpace', 'Delete', 'Left', 'Right', 'Up', 'Down']: return
        entry = self.entries_tutor["celular"]
        texto = entry.get()
        digitos = ''.join(filter(str.isdigit, texto))[:11]
        formatado = ""
        for i, d in enumerate(digitos):
            if i == 0: formatado += "("
            if i == 2: formatado += ") "
            if i == 3: formatado += " "
            if i == 7: formatado += "-"
            formatado += d
        if texto != formatado:
            entry.delete(0, tk.END); entry.insert(0, formatado)

    def formatar_cep(self, event):
        """Aplica a máscara 00.000-000 para CEPs."""
        if event.keysym in ['BackSpace', 'Delete', 'Left', 'Right', 'Up', 'Down']: return
        entry = self.entries_tutor["cep"]
        texto = entry.get()
        digitos = ''.join(filter(str.isdigit, texto))[:8]
        formatado = ""
        for i, d in enumerate(digitos):
            if i == 2: formatado += "."
            if i == 5: formatado += "-"
            formatado += d
        if texto != formatado:
            entry.delete(0, tk.END); entry.insert(0, formatado)

    def formatar_campo_busca(self, event, entry_widget, tipo_var):
        """
        Formatação inteligente de input:
        Alterna entre a máscara de CPF e a de Código de Pet (AAA-000) baseado no Radiobutton selecionado.
        """
        if event.keysym in ['BackSpace', 'Delete', 'Left', 'Right', 'Up', 'Down']: return
        tipo = tipo_var.get()
        texto = entry_widget.get()
        if tipo == "CPF":
            digitos = ''.join(filter(str.isdigit, texto))[:11]
            formatado = ""
            for i, d in enumerate(digitos):
                if i in [3, 6]: formatado += "."
                if i == 9: formatado += "-"
                formatado += d
            if texto != formatado:
                entry_widget.delete(0, tk.END); entry_widget.insert(0, formatado)
        elif tipo == "COD":
            chars = ''.join(c for c in texto if c.isalnum()).upper()[:6]
            formatado = ""
            for i, c in enumerate(chars):
                if i == 3: formatado += "-"
                formatado += c
            if texto != formatado:
                entry_widget.delete(0, tk.END); entry_widget.insert(0, formatado)

