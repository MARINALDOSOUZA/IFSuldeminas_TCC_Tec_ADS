    def carregar_relatorio(self):
        """
        Executa múltiplos JOINs/Buscas iterativas em todo o banco (Tutor, Pet, Cuidados e Vacinas)
        Formata o texto extraído para visualização e preparação do buffer do PDF.
        """
        termo = self.ent_rel_busca.get().strip(); tipo = self.var_rel_tipo.get()
        self.txt_relatorio.delete(1.0, tk.END); self.relatorio_dados = None
        if not termo: return
        
        if tipo == "CPF": pets = self.db.executar("SELECT * FROM pet WHERE cpf_tutor=?", (termo,)).fetchall()
        else: pets = self.db.executar("SELECT * FROM pet WHERE codigo=?", (termo,)).fetchall()
            
        if not pets:
            self.txt_relatorio.insert(tk.END, "Nenhum registro encontrado.")
            return
            
        if len(pets) > 1:
            messagebox.showinfo("Aviso", "Múltiplos pets encontrados para este CPF.\nMostrando relatório do primeiro. Para um relatório específico, pesquise pela opção Código do Pet.")
            
        pet = pets[0]
        tutor = self.db.executar("SELECT * FROM tutor WHERE cpf=?", (pet[1],)).fetchone()
        cuidados = self.db.executar("SELECT * FROM cuidados WHERE codigo_pet=?", (pet[0],)).fetchone()
        vacinas = self.db.executar("SELECT * FROM vacinas WHERE codigo_pet=?", (pet[0],)).fetchall()
        
        # Concatenação e formatação em string de exibição/buffer
        texto = f"========== RELATÓRIO CLÍNICO ==========\n\n"
        texto += f"--- DADOS DO TUTOR ---\n"
        texto += f"Nome: {tutor[1]} | CPF: {tutor[0]} | Celular: {tutor[2]}\n"
        texto += f"E-mail: {tutor[3]} | Endereço: {tutor[5]}, {tutor[6]} - {tutor[7]}/{tutor[8]} - CEP: {tutor[4]}\n"
        texto += f"[Registrado/Atualizado por: {tutor[9]}]\n\n"
        
        texto += f"--- DADOS DO PET ---\n"
        texto += f"Nome: {pet[2]} | Código: {pet[0]} | Tipo: {pet[3]} | Raça: {pet[4]}\n"
        texto += f"Porte: {pet[5]} | Nasc.: {pet[6]} | Sexo: {pet[7]} | Cor: {pet[8]}\n"
        texto += f"[Registrado/Atualizado por: {pet[9]}]\n\n"
        
        if cuidados:
            texto += f"--- CUIDADOS ---\n"
            texto += f"Alimentação: {cuidados[1]}\nHorários: {cuidados[2]}\nAlergias: {cuidados[3]}\n"
            texto += f"[Registrado/Atualizado por: {cuidados[4]}]\n\n"
            
        if vacinas:
            texto += f"--- VACINAS ---\n"
            for v in vacinas:
                texto += f"- {v[2]} (Protege: {v[3]} | Duração: {v[4]} | Próx. Dose: {v[5]}) [por: {v[6]}]\n"
        
        self.txt_relatorio.insert(tk.END, texto)
        self.relatorio_dados = {"tutor": tutor, "pet": pet, "texto": texto} # Salva em dict para fácil acesso pela função de PDF

    def gerar_pdf(self):
        """
        Gera a compilação do relatório em formato `.pdf`.
        Utiliza `latin-1` para converter carateres e evitar desconfiguração de acentos PT-BR.
        Utiliza `multi_cell` para permitir quebra de linha em textos longos.
        """
        if getattr(self, 'relatorio_dados', None) is None: return messagebox.showwarning("Aviso", "Por favor, carregue os dados de um pet primeiro.")
            
        tutor = self.relatorio_dados["tutor"]; pet = self.relatorio_dados["pet"]
        cpf_limpo = tutor[0].replace(".", "").replace("-", ""); cod_limpo = pet[0].replace("-", "")
        agora = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        nome_arquivo = f"{cpf_limpo}.{cod_limpo}.{agora}.pdf"
        
        caminho_salvar = filedialog.asksaveasfilename(defaultextension=".pdf", initialfile=nome_arquivo, title="Salvar Relatório PDF", filetypes=[("PDF Files", "*.pdf")])
        if not caminho_salvar: return
        
        pdf = FPDF(); pdf.add_page(); pdf.set_font("Arial", size=11)
        for linha in self.relatorio_dados["texto"].split('\n'):
            # Encodifica texto e utiliza multi_cell
            texto_limpo = linha.encode('latin-1', 'replace').decode('latin-1')
            pdf.multi_cell(0, 6, txt=texto_limpo)
            
        try:
            pdf.output(caminho_salvar)
            messagebox.showinfo("Sucesso", f"Documento salvo com sucesso em:\n{caminho_salvar}")
        except Exception as e:
            messagebox.showerror("Erro ao salvar PDF", str(e))

