    def salvar_tutor(self):
        """
        Salva ou atualiza os dados do tutor.
        Integra lógica de prevenção de duplicação: alerta o usuário se o CPF já existir 
        e oferece a opção de modificar os dados (*Update*) ou ignorar (*Skip*).
        """
        v = {k: var.get().strip() for k, var in self.vars_tutor.items()}
        if not v["cpf"] or not v["nome"]: return messagebox.showwarning("Aviso", "CPF e Nome são obrigatórios para prosseguir!")
            
        try:
            tutor_existe = self.db.executar("SELECT nome FROM tutor WHERE cpf=?", (v["cpf"],)).fetchone()
            if tutor_existe:
                decisao = messagebox.askyesno("Tutor Cadastrado", f"O CPF {v['cpf']} já pertence a {tutor_existe[0]}.\n\nDeseja ATUALIZAR os dados deste tutor ou PROSSEGUIR para o cadastro de Pet?")
                if decisao: 
                    self.db.executar("UPDATE tutor SET nome=?, celular=?, email=?, cep=?, endereco=?, bairro=?, cidade=?, uf=?, usuario_registro=? WHERE cpf=?", 
                                     (v["nome"], v["celular"], v["email"], v["cep"], v["endereco"], v["bairro"], v["cidade"], v["uf"], self.usuario_logado, v["cpf"]))
                    messagebox.showinfo("Sucesso", "Dados do tutor atualizados!")
            else:
                self.db.executar("INSERT INTO tutor VALUES (?,?,?,?,?,?,?,?,?,?)", 
                                 (v["cpf"], v["nome"], v["celular"], v["email"], v["cep"], v["endereco"], v["bairro"], v["cidade"], v["uf"], self.usuario_logado))
                messagebox.showinfo("Sucesso", "Tutor cadastrado! Avançando para o cadastro do Pet.")

            # Avança o fluxo carregando a Primary Key (CPF) para a Foreign Key do Pet
            self.ent_pet_cpf.config(state="normal"); self.ent_pet_cpf.delete(0, tk.END); self.ent_pet_cpf.insert(0, v["cpf"]); self.ent_pet_cpf.config(state="readonly")
            self.sub_notebook.select(self.sub_abas["pet"])
        except Exception as e:
            messagebox.showerror("Erro", str(e))

