    def calcular_idade(self, event):
        """Converte o input de string para datetime e calcula a idade real baseada na data atual do SO."""
        try:
            nasc = datetime.datetime.strptime(self.ent_pet_nasc.get().strip(), "%d/%m/%Y")
            hoje = datetime.datetime.today()
            anos = hoje.year - nasc.year - ((hoje.month, hoje.day) < (nasc.month, nasc.day))
            self.lbl_idade.config(text=f"Idade: {anos} anos")
        except:
            self.lbl_idade.config(text="Idade: Inválida")

    def salvar_pet(self):
        """
        Salva ou atualiza os dados biológicos do Pet. 
        Gera algoritmicamente um código alfa-numérico único caso seja um registro novo.
        """
        cpf = self.ent_pet_cpf.get(); nome = self.ent_pet_nome.get().strip(); tipo = self.cb_pet_tipo.get()
        raca = self.ent_pet_raca.get().strip(); porte = self.cb_pet_porte.get(); nasc = self.ent_pet_nasc.get().strip()
        sexo = self.cb_pet_sexo.get(); cor = self.ent_pet_cor.get().strip()

        if not cpf: return messagebox.showwarning("Aviso", "Cadastre um Tutor primeiro!")
        if not (nome and tipo and porte and nasc and sexo): return messagebox.showwarning("Aviso", "Os campos marcados com * são obrigatórios!")

        try:
            # Modo de Edição Ativo (Update)
            if self.codigo_em_edicao:
                codigo = self.codigo_em_edicao
                self.db.executar("UPDATE pet SET cpf_tutor=?, nome=?, tipo=?, raca=?, porte=?, dt_nasc=?, sexo=?, cor=?, usuario_registro=? WHERE codigo=?", 
                                 (cpf, nome, tipo, raca, porte, nasc, sexo, cor, self.usuario_logado, codigo))
                messagebox.showinfo("Sucesso", f"Pet código {codigo} atualizado!")
                self.codigo_em_edicao = None
            # Modo Criação Ativo (Insert)
            else:
                letras = ''.join(random.choices(string.ascii_uppercase, k=3)); numeros = ''.join(random.choices(string.digits, k=3))
                codigo = f"{letras}-{numeros}"
                self.db.executar("INSERT INTO pet VALUES (?,?,?,?,?,?,?,?,?,?)", 
                                 (codigo, cpf, nome, tipo, raca, porte, nasc, sexo, cor, self.usuario_logado))
                messagebox.showinfo("Sucesso", f"Pet registrado com o Código: {codigo}\nAvançando para Cuidados.")
            
            # Carrega a PK gerada (Código) nas foreign keys de Cuidados e Vacinas
            for campo in [self.ent_care_cod, self.ent_vax_cod]:
                campo.config(state="normal"); campo.delete(0, tk.END); campo.insert(0, codigo); campo.config(state="readonly")
            self.sub_notebook.select(self.sub_abas["care"])
        except Exception as e:
